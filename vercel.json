{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "ia.solcopywriting.com" }],
      "destination": "/ia/$1"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "quizz.solcopywriting.com" }],
      "destination": "/quizz/:path*"
    }
  ]
}
