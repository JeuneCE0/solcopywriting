{
  "routes": [
    { "has": [{ "type": "host", "value": "lecopyquiz.com" }],          "src": "/(ads|orga)",   "dest": "/quiz/index.html" },
    { "has": [{ "type": "host", "value": "www.lecopyquiz.com" }],      "src": "/(ads|orga)",   "dest": "/quiz/index.html" },
    { "has": [{ "type": "host", "value": "lecopyquiz.com" }],          "src": "/lp",           "dest": "/quiz/lp/index.html" },
    { "has": [{ "type": "host", "value": "www.lecopyquiz.com" }],      "src": "/lp",           "dest": "/quiz/lp/index.html" },
    { "has": [{ "type": "host", "value": "lecopyquiz.com" }],          "src": "/",             "dest": "/quiz/lp/index.html" },
    { "has": [{ "type": "host", "value": "www.lecopyquiz.com" }],      "src": "/",             "dest": "/quiz/lp/index.html" },
    { "has": [{ "type": "host", "value": "lecopyquiz.com" }],          "src": "/((?!api/).*)", "dest": "/quiz/$1" },
    { "has": [{ "type": "host", "value": "www.lecopyquiz.com" }],      "src": "/((?!api/).*)", "dest": "/quiz/$1" },
    { "has": [{ "type": "host", "value": "quizz.solcopywriting.com" }], "src": "/(.*)",         "dest": "/quiz/$1" },
    { "has": [{ "type": "host", "value": "ia.solcopywriting.com" }],   "src": "/((?!api/).*)", "dest": "/ia/$1" },
    { "handle": "filesystem" }
  ]
}
